# ===== Database =====
DATABASE_URL=postgresql://localhost:5432/socialmedia

# ===== Authentication =====
JWT_SECRET=change-this-to-a-random-32-character-string-please

# ===== Server =====
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
ADMIN_SECRET=change-this-to-a-random-secret

# ===== AI: Text Generation =====
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI — ChatGPT queries for GEO Audit
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Perplexity — AI search queries for GEO Audit (uses live web search)
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your-key-here

# ===== AI: Image Generation =====
# Default provider: choose 'nanobanana', 'midjourney', or 'auto'
IMAGE_PROVIDER=nanobanana

# NanoBanana (Google Gemini 2.5 Flash Image) — RECOMMENDED, cheapest
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-key-here

# Midjourney via Replicate (alternative)
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your-token-here

# ===== AI: Video Generation =====
# HeyGen — Avatar (talking-head) video
# Get from: https://app.heygen.com/settings/api
HEYGEN_API_KEY=your-heygen-key-here
# Optional overrides for HeyGen avatar/voice
HEYGEN_VOICE_ID=
HEYGEN_AVATAR_ID=
# Set to true in development to get watermarked videos (saves HeyGen credits)
HEYGEN_TEST_MODE=false
# Required: HeyGen will sign webhook payloads with this secret
HEYGEN_WEBHOOK_SECRET=your-heygen-webhook-secret

# Veo 3.1 Fast — Services/Reel video generation (Preview — disabled by default)
# Uses the same GOOGLE_AI_API_KEY as NanoBanana — no new key needed
# Set to 'true' when Veo 3.1 is stable for your Google AI Studio plan
VEO_ENABLED=false

# ===== Media Storage =====
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===== Payments (Whop — NOT Stripe) =====
# Stripe is unavailable in Pakistan. Whop is the Merchant of Record (handles all taxes globally).
# Get from: https://whop.com/dashboard → Settings → API
WHOP_API_KEY=
WHOP_WEBHOOK_KEY=
# Whop plan IDs — monthly and yearly for each tier
PLAN_STARTER_M_WHOP_ID=
PLAN_STARTER_Y_WHOP_ID=
PLAN_PRO_M_WHOP_ID=
PLAN_PRO_Y_WHOP_ID=
PLAN_PREMIUM_M_WHOP_ID=
PLAN_PREMIUM_Y_WHOP_ID=
# Whop one-time credit pack product IDs (25/50/75/.../250 credits)
CREDIT_25_WHOP_ID=
CREDIT_50_WHOP_ID=
CREDIT_75_WHOP_ID=
CREDIT_100_WHOP_ID=
CREDIT_125_WHOP_ID=
CREDIT_150_WHOP_ID=
CREDIT_175_WHOP_ID=
CREDIT_200_WHOP_ID=
CREDIT_225_WHOP_ID=
CREDIT_250_WHOP_ID=

# ===== Web Push Notifications (PWA) =====
# Generate keys once: node -e "require('web-push').generateVAPIDKeys().then(k=>console.log(k))"
# Or: npx web-push generate-vapid-keys
# Leave blank to disable push notifications (in-app notifications still work)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=support@itsposting.com

# ===== Email (Resend) =====
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-key-here
# Set to 'resend' to send real emails; 'log' logs to console only (default for dev)
EMAIL_PROVIDER=log
EMAIL_FROM_NAME=ItsPosting
EMAIL_FROM_ADDRESS=noreply@app.itsposting.com

# Resend bounce/complaint webhook signing secret (starts with whsec_)
# Setup: Resend dashboard → Webhooks → Add endpoint
#   URL:    https://api.itsposting.com/api/email/resend-webhook
#   Events: email.bounced, email.complained
#   Copy the signing secret below
RESEND_WEBHOOK_SECRET=whsec_your-signing-secret-here

# ── DNS Records required for email deliverability ─────────────────────────────
# Set these in your domain registrar (e.g., Cloudflare, GoDaddy, Namecheap).
# All three are required for Gmail/Yahoo bulk sender compliance (mandatory Feb 2024+).
#
# 1. SPF  (TXT record on itsposting.com)
#    Name:  @  (root domain)
#    Value: v=spf1 include:resend.com ~all
#
# 2. DKIM (CNAME record — Resend provides exact values in their dashboard)
#    Resend dashboard → Domains → Add domain → copy the 3 CNAME records
#    Example: resend._domainkey.itsposting.com → CNAME → dkim.resend.com
#
# 3. DMARC (TXT record on _dmarc.itsposting.com)
#    Name:  _dmarc
#    Value: v=DMARC1; p=quarantine; rua=mailto:dmarc@itsposting.com; pct=100
#    Note:  Start with p=none for monitoring, then move to p=quarantine after 2 weeks
#
# Verification: Check https://mxtoolbox.com/emailhealth/ after DNS propagation (24-48h)
# ─────────────────────────────────────────────────────────────────────────────

# ===== Security: Background Jobs =====
# Required to call POST /api/suggestions/generate-daily
# Generate with: openssl rand -hex 32
CRON_SECRET=change-this-to-a-random-secret

# ===== Social OAuth =====
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=any-string-you-choose
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TIKTOK_APP_SECRET=

# ===== Stock Photos (optional — any combination works) =====
# Free, no attribution required:
PIXABAY_API_KEY=
PEXELS_API_KEY=
# Paid — add when subscriptions are in place:
# SHUTTERSTOCK_API_KEY=
# SHUTTERSTOCK_API_SECRET=
# STORYBLOCKS_PUBLIC_KEY=
# STORYBLOCKS_PRIVATE_KEY=
# MAGNIFIC_API_KEY=

# ===== fal.ai — Cinematic video fallback chain =====
# Get from: https://fal.ai/dashboard → API Keys ($20 free credits at signup)
FAL_API_KEY=

# ===== Pika 2.2 — Video fallback (Pro plan $8/mo required for API) =====
PIKA_API_KEY=

# ===== Agency White-Label =====
# AES-256 encryption key for agency SMTP credentials stored in DB
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ===== Google Business Messages =====
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_BUSINESS_AGENT_ID=
GMB_WEBHOOK_CLIENT_TOKEN=

# ===== Email Admin =====
ADMIN_ALERT_EMAIL=your-email@example.com

# ===== Stock Media Tuning (optional — defaults shown) =====
# STOCK_TIMEOUT_MS=3000
# STOCK_NANO_DELAY_MS=2000
# STOCK_VALIDATION_THRESHOLD=70
