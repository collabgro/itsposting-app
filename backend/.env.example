# ===== Database =====
DATABASE_URL=postgresql://localhost:5432/socialmedia

# ===== Authentication =====
JWT_SECRET=change-this-to-a-random-32-character-string-please

# ===== Server =====
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5000

# ===== AI: Text Generation =====
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ===== AI: Image Generation =====
# Default provider: choose 'nanobanana', 'midjourney', or 'auto'
IMAGE_PROVIDER=nanobanana

# NanoBanana (Google Gemini 2.5 Flash Image) — RECOMMENDED, cheapest
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-key-here

# Midjourney via Replicate (alternative)
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your-token-here

# ===== AI: Video Generation =====
# HeyGen — Avatar (talking-head) video
# Get from: https://app.heygen.com/settings/api
HEYGEN_API_KEY=your-heygen-key-here
# Optional overrides for HeyGen avatar/voice
HEYGEN_VOICE_ID=
HEYGEN_AVATAR_ID=
# Set to true in development to get watermarked videos (saves HeyGen credits)
HEYGEN_TEST_MODE=false
# Required: HeyGen will sign webhook payloads with this secret
HEYGEN_WEBHOOK_SECRET=your-heygen-webhook-secret

# Veo 3.1 Fast — Services/Reel video generation (Preview — disabled by default)
# Uses the same GOOGLE_AI_API_KEY as NanoBanana — no new key needed
# Set to 'true' when Veo 3.1 is stable for your Google AI Studio plan
VEO_ENABLED=false

# ===== Media Storage =====
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===== Payments (Lemon Squeezy — NOT Stripe) =====
# Stripe is unavailable in Pakistan. Use Lemon Squeezy as Merchant of Record.
# Get from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
# Lemon Squeezy variant IDs for each plan
PLAN_STARTER_ID=
PLAN_PRO_ID=
PLAN_AGENCY_ID=

# ===== Email (Resend) =====
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-key-here
# Set to 'resend' to send real emails; 'log' logs to console only (default for dev)
EMAIL_PROVIDER=log
EMAIL_FROM_NAME=Its Posting
EMAIL_FROM_ADDRESS=noreply@app.itsposting.com

# ===== Security: Background Jobs =====
# Required to call POST /api/suggestions/generate-daily
# Generate with: openssl rand -hex 32
CRON_SECRET=change-this-to-a-random-secret

# ===== Social OAuth =====
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
