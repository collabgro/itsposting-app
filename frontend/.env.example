# Local development: optional — defaults to http://127.0.0.1:3001 in next.config.js
# BACKEND_URL=http://127.0.0.1:3001

# Netlify (required): public origin of your deployed Express API, no trailing slash
# BACKEND_URL=https://your-api.example.com

# Netlify only — escape hatch if you must build without BACKEND_URL set (not recommended)
# SKIP_BACKEND_URL_CHECK=1
