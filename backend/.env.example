# ===== Database =====
DATABASE_URL=postgresql://localhost:5432/socialmedia

# ===== Authentication =====
JWT_SECRET=change-this-to-a-random-32-character-string-please

# ===== Server =====
PORT=3001
NODE_ENV=development
# Use your Netlify site URL in production (OAuth redirects, emails, CORS behavior)
FRONTEND_URL=http://localhost:5000

# ===== AI: Text Generation =====
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ===== AI: Image Generation =====
# Default provider: choose 'nanobanana', 'midjourney', or 'auto'
IMAGE_PROVIDER=nanobanana

# NanoBanana (Google Gemini 2.5 Flash Image) - RECOMMENDED, cheapest
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-key-here

# Midjourney via Replicate (alternative)
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your-token-here

# ===== AI: Video Generation =====
# Get from: https://app.heygen.com/settings/api
HEYGEN_API_KEY=your-heygen-key-here

# ===== Media Storage =====
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===== Payments (Optional) =====
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ===== Social OAuth (Optional) =====
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
